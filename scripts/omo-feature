#!/usr/bin/env bash
set -euo pipefail

# omo-feature: Full-Auto from PRD workflow
# Usage: omo-feature <issue-id> <repo> [--background]

SCRIPT_NAME="$(basename "$0")"
LOG_DIR="${HOME}/.local/share/omo-fix"
mkdir -p "$LOG_DIR"

show_usage() {
    cat << 'USAGEEOF'
Usage:
  omo-feature <issue-id> <repo> [--background]     Start feature development
  omo-feature --background <issue-id> <repo>       Same as above
  omo-feature --status <pid>                        Check status
  omo-feature --list                                List running jobs
  omo-feature --logs <issue-id>                     View logs
  omo-feature --kill <pid>                          Kill a job

Examples:
  omo-feature 123 owner/repo                    # Foreground
  omo-feature 123 owner/repo --background       # Background
  omo-feature --status 12345                     # Check status
USAGEEOF
}

BACKGROUND=false
ISSUE_ID=""
REPO=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --background|-b)
            BACKGROUND=true
            shift
            ;;
        --status|--list|--logs|--kill|--help|-h)
            ACTION="$1"
            shift
            case "$ACTION" in
                --status|--logs|--kill)
                    if [[ -z "${1:-}" ]]; then
                        echo "Error: $ACTION requires an argument"
                        exit 1
                    fi
                    ARG="$1"
                    shift
                    ;;
            esac
            
            case "$ACTION" in
                --status)
                    if ps -p "$ARG" > /dev/null 2>&1; then
                        echo "Job $ARG is running"
                        LOG_FILE=$(find "$LOG_DIR" -name "*-$ARG.log" 2>/dev/null | head -1)
                        [[ -n "$LOG_FILE" ]] && echo "Log: $LOG_FILE" && tail -20 "$LOG_FILE"
                    else
                        echo "Job $ARG not running"
                        LOG_FILE=$(find "$LOG_DIR" -name "*-$ARG.log" 2>/dev/null | head -1)
                        [[ -n "$LOG_FILE" ]] && echo "Final log: $LOG_FILE"
                    fi
                    exit 0
                    ;;
                --list)
                    echo "Running jobs:"
                    ps aux | grep -E "[o]mo-feature" | grep -v grep || echo "None"
                    echo ""
                    echo "Logs:"
                    ls -lt "$LOG_DIR"/*.log 2>/dev/null | head -5 || echo "None"
                    exit 0
                    ;;
                --logs)
                    LOG_FILE=$(find "$LOG_DIR" -name "*feature-${ARG}-*.log" 2>/dev/null | head -1)
                    if [[ -f "$LOG_FILE" ]]; then
                        echo "Logs for issue #$ARG:"
                        tail -50 "$LOG_FILE"
                    else
                        echo "No logs for issue #$ARG"
                    fi
                    exit 0
                    ;;
                --kill)
                    if kill "$ARG" 2>/dev/null; then
                        echo "Killed job $ARG"
                    else
                        echo "Could not kill job $ARG"
                    fi
                    exit 0
                    ;;
                --help|-h)
                    show_usage
                    exit 0
                    ;;
            esac
            ;;
        -*)
            echo "Unknown: $1"
            show_usage
            exit 1
            ;;
        *)
            if [[ -z "$ISSUE_ID" ]]; then
                ISSUE_ID="$1"
            elif [[ -z "$REPO" ]]; then
                REPO="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$ISSUE_ID" || -z "$REPO" ]]; then
    show_usage
    exit 1
fi

# Check deps
for cmd in gh jq git; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: $cmd not installed"
        exit 1
    fi
done

if ! gh auth status &> /dev/null; then
    echo "Error: gh not authenticated"
    exit 1
fi

# Background mode
if [[ "$BACKGROUND" == true ]]; then
    TIMESTAMP=$(date +%s)
    LOG_FILE="$LOG_DIR/omo-feature-issue-${ISSUE_ID}-${TIMESTAMP}.log"
    
    echo "Starting in background..."
    echo "Issue: #$ISSUE_ID, Repo: $REPO"
    echo "Log: $LOG_FILE"
    
    # Write the background script
    BG_SCRIPT="$LOG_DIR/.bg-feature-script-${TIMESTAMP}.sh"
    cat > "$BG_SCRIPT" << BGEOF
#!/bin/bash
exec > "$LOG_FILE" 2>&1

echo "=== omo-feature started at \$(date) ==="
echo "Issue: $ISSUE_ID, Repo: $REPO"
echo "PID: \$\$"

WORKDIR=\$(mktemp -d)
echo "Workspace: \$WORKDIR"

REPO_NAME="${REPO#*/}"
REPO_DIR="\$WORKDIR/\$REPO_NAME"

# Clone
echo "Cloning $REPO..."
gh repo clone "$REPO" "\$REPO_DIR"
cd "\$REPO_DIR"

# Git setup
git config user.email "omo-feature@automation.local"
git config user.name "OMO Feature Bot"

# Branch
BRANCH="fix-issue-${ISSUE_ID}-\$(date +%s)"
git checkout -b "\$BRANCH"

# Fetch issue
echo "Fetching issue #$ISSUE_ID..."
ISSUE_JSON=\$(gh issue view "$ISSUE_ID" --repo "$REPO" --json title,body,url)
TITLE=\$(echo "\$ISSUE_JSON" | jq -r '.title')
BODY=\$(echo "\$ISSUE_JSON" | jq -r '.body')
ISSUE_URL=\$(echo "\$ISSUE_JSON" | jq -r '.url')

echo "Issue: \$TITLE"
echo "Issue URL: \$ISSUE_URL"
echo ""
echo "Workflow complete. Branch \$BRANCH created."
echo "=== omo-feature ready at \$(date) ==="
rm -f "$BG_SCRIPT"
BGEOF
    
    chmod +x "$BG_SCRIPT"
    
    # Start in background
    nohup bash "$BG_SCRIPT" &
    BG_PID=$!
    
    echo ""
    echo "Started with PID: $BG_PID"
    echo "Commands:"
    echo "  omo-feature --status $BG_PID     # Check status"
    echo "  omo-feature --logs $ISSUE_ID     # View logs"
    echo "  omo-feature --kill $BG_PID       # Stop the job"
    echo "  tail -f $LOG_FILE                 # Watch live logs"
    echo ""
    
    exit 0
fi

# ===== FOREGROUND MODE =====

echo "🔍 Fetching issue #$ISSUE_ID from $REPO..."

# Fetch issue details
ISSUE_JSON=$(gh issue view "$ISSUE_ID" --repo "$REPO" --json title,body,url 2>/dev/null) || {
    echo "Error fetching issue"
    exit 1
}

TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
BODY=$(echo "$ISSUE_JSON" | jq -r '.body')
ISSUE_URL=$(echo "$ISSUE_JSON" | jq -r '.url')

echo "📋 Issue: $TITLE"
echo "🔗 Issue URL: $ISSUE_URL"
echo ""

WORKDIR=$(mktemp -d)
echo "📁 Workspace: $WORKDIR"

REPO_NAME="${REPO#*/}"
REPO_DIR="$WORKDIR/$REPO_NAME"

echo "📥 Cloning $REPO..."
gh repo clone "$REPO" "$REPO_DIR"
cd "$REPO_DIR"

git config user.email "omo-feature@automation.local"
git config user.name "OMO Feature Bot"

BRANCH="feature-issue-${ISSUE_ID}-$(date +%s)"
echo "🌿 Creating branch: $BRANCH"
git checkout -b "$BRANCH"

echo ""
echo "✅ Setup complete!"
echo "   Branch: $BRANCH"
echo "   Directory: $REPO_DIR"
echo "   Ready for agent workflow execution"
