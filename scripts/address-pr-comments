#!/usr/bin/env bash
set -euo pipefail

# address-pr-comments: Autonomously address PR review comments
# Usage: address-pr-comments <pr-number> <repo> [--background]

SCRIPT_NAME="$(basename "$0")"
LOG_DIR="${HOME}/.local/share/omo-fix"
mkdir -p "$LOG_DIR"

show_usage() {
    cat << 'USAGEEOF'
Usage:
  address-pr-comments <pr-number> <repo> [--background]
  address-pr-comments --status <pid>
  address-pr-comments --list
  address-pr-comments --logs <pr-number>

Examples:
  address-pr-comments 43 tanvesh01/paper-portfolio
  address-pr-comments 43 tanvesh01/paper-portfolio --background
USAGEEOF
}

BACKGROUND=false
PR_NUMBER=""
REPO=""

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --background|-b)
            BACKGROUND=true
            shift
            ;;
        --status)
            shift
            ARG="$1"
            if ps -p "$ARG" > /dev/null 2>&1; then
                echo "Job $ARG is running"
                LOG_FILE=$(find "$LOG_DIR" -name "*-$ARG.log" 2>/dev/null | head -1)
                [[ -n "$LOG_FILE" ]] && echo "Log: $LOG_FILE" && tail -20 "$LOG_FILE"
            else
                echo "Job $ARG not running"
            fi
            exit 0
            ;;
        --list)
            echo "Running jobs:"
            ps aux | grep -E "[a]ddress-pr-comments" | grep -v grep || echo "None"
            exit 0
            ;;
        --logs)
            shift
            ARG="$1"
            LOG_FILE=$(find "$LOG_DIR" -name "*pr-${ARG}-*.log" 2>/dev/null | head -1)
            if [[ -f "$LOG_FILE" ]]; then
                echo "Logs for PR #$ARG:"
                tail -50 "$LOG_FILE"
            else
                echo "No logs for PR #$ARG"
            fi
            exit 0
            ;;
        --help|-h)
            show_usage
            exit 0
            ;;
        -*)
            echo "Unknown: $1"
            show_usage
            exit 1
            ;;
        *)
            if [[ -z "$PR_NUMBER" ]]; then
                PR_NUMBER="$1"
            elif [[ -z "$REPO" ]]; then
                REPO="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "$PR_NUMBER" || -z "$REPO" ]]; then
    show_usage
    exit 1
fi

# Check deps
for cmd in gh jq git; do
    if ! command -v "$cmd" &> /dev/null; then
        echo "Error: $cmd not installed"
        exit 1
    fi
done

if ! gh auth status &> /dev/null; then
    echo "Error: gh not authenticated"
    exit 1
fi

# ===== FOREGROUND MODE =====

echo "🔍 Fetching PR #$PR_NUMBER from $REPO..."

# Fetch PR details
PR_JSON=$(gh pr view "$PR_NUMBER" --repo "$REPO" --json headRefName,baseRefName,title 2>/dev/null) || {
    echo "Error fetching PR"
    exit 1
}

HEAD_BRANCH=$(echo "$PR_JSON" | jq -r '.headRefName')
BASE_BRANCH=$(echo "$PR_JSON" | jq -r '.baseRefName')
PR_TITLE=$(echo "$PR_JSON" | jq -r '.title')

echo "📋 PR: $PR_TITLE"
echo "🌿 Branch: $HEAD_BRANCH (base: $BASE_BRANCH)"
echo ""

WORKDIR=$(mktemp -d)
echo "📁 Workspace: $WORKDIR"

REPO_NAME="${REPO#*/}"
REPO_DIR="$WORKDIR/$REPO_NAME"

echo "📥 Cloning $REPO..."
gh repo clone "$REPO" "$REPO_DIR"
cd "$REPO_DIR"

echo "🔄 Fetching PR branch..."
git fetch origin "$HEAD_BRANCH"
git checkout "$HEAD_BRANCH"

git config user.email "address-pr-comments@automation.local"
git config user.name "PR Comments Bot"

echo "💬 Fetching comments..."
COMMENTS_JSON=$(gh pr view "$PR_NUMBER" --repo "$REPO" --comments --json comments)
COMMENT_COUNT=$(echo "$COMMENTS_JSON" | jq '.comments | length')

echo "Found $COMMENT_COUNT comments"
echo ""

echo "🚀 Ready for agent execution"
echo "   Run: /address-pr-comments $PR_NUMBER $REPO"
echo "   Directory: $REPO_DIR"
echo ""
